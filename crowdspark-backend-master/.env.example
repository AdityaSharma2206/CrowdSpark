# MongoDB connection string
# Local:  mongodb://localhost:27017/crowdspark
# Atlas:  mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
DATABASE_URL=

# JWT signing secret — any long random string, e.g: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Stripe secret key — get from https://dashboard.stripe.com → Developers → API keys
# Use sk_test_... for local development
STRIPE_SECRET_KEY=

# Port the Express server listens on (optional, defaults to 5050)
PORT=5050

# Admin seed credentials — used only by: npm run seed
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=
